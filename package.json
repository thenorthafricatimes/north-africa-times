{
  "name": "north-africa-times",
  "version": "1.0.0",
  "description": "North Africa Times - Intelligence Platform for 6 Countries",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "scan": "python3 scanner.py",
    "setup": "npm install && python3 -m pip install -r requirements.txt",
    "db:init": "psql -U postgres -f database/schema.sql"
  },
  "keywords": [
    "news",
    "north-africa",
    "algeria",
    "morocco",
    "egypt",
    "tunisia",
    "libya",
    "mauritania",
    "intelligence",
    "api"
  ],
  "author": "North Africa Times",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "axios": "^1.6.0",
    "pg": "^8.11.3",
    "node-cron": "^3.0.3",
    "dotenv": "^16.3.1",
    "helmet": "^7.1.0",
    "compression": "^1.7.4",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
